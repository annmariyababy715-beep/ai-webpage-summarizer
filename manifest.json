{
  "manifest_version": 3,
  "name": "AI Webpage Summarizer",
  "version": "1.0",

  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
  "<all_urls>",
  "https://api.groq.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  }
}